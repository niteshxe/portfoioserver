<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CMS // REGISTER</title>
    <style>
        :root {
            --bg-color: #050505;
            --text-main: #ffffff;
            --accent-color: #00FF41; /* Green for registration */
            --border-light: rgba(255, 255, 255, 0.15);
        }

        body {
            background: var(--bg-color);
            color: var(--text-main);
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            padding: 2rem;
        }

        .register-card {
            width: 100%;
            max-width: 400px;
            border: 1px solid var(--border-light);
            padding: 3rem;
            background: #0a0a0a;
            position: relative;
        }

        .register-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 4px;
            background: var(--accent-color);
        }

        h1 {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        input {
            background: #111;
            border: 1px solid var(--border-light);
            color: var(--text-main);
            padding: 1rem;
            width: 100%;
            margin-bottom: 1.5rem;
            box-sizing: border-box;
            font-family: inherit;
        }

        input:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        button {
            background: var(--accent-color);
            color: #000;
            border: none;
            padding: 1rem;
            width: 100%;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        button:hover {
            background: #fff;
            color: #000;
        }

        .error {
            color: #FF1100;
            font-size: 0.8rem;
            margin-bottom: 1.5rem;
            text-transform: uppercase;
        }

        .login-link {
            display: block;
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.8rem;
            color: #666;
            text-decoration: none;
            text-transform: uppercase;
        }

        .login-link:hover {
            color: var(--accent-color);
        }
    </style>
</head>
<body>
    <div class="register-card">
        <h1>CMS // REGISTER</h1>
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        <form action="/register" method="POST">
            <input type="text" name="username" placeholder="USERNAME" required>
            <input type="email" name="email" placeholder="EMAIL ADDRESS" required>
            <input type="password" name="password" placeholder="PASSWORD" required>
            <button type="submit">Send Verification OTP</button>
        </form>
        <a href="/login" class="login-link">Back to login</a>
    </div>
</body>
</html>
