<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CMS // VERIFY OTP</title>
    <style>
        :root {
            --bg-color: #050505;
            --text-main: #ffffff;
            --accent-color: #0088FF; /* blue for verification */
            --border-light: rgba(255, 255, 255, 0.15);
        }

        body {
            background: var(--bg-color);
            color: var(--text-main);
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            padding: 2rem;
        }

        .verify-card {
            width: 100%;
            max-width: 400px;
            border: 1px solid var(--border-light);
            padding: 3rem;
            background: #0a0a0a;
            position: relative;
        }

        .verify-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 4px;
            background: var(--accent-color);
        }

        h1 {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        p {
            font-size: 0.8rem;
            color: #888;
            margin-bottom: 2rem;
            line-height: 1.5;
        }

        .email-display {
            color: #fff;
            font-weight: bold;
        }

        input {
            background: #111;
            border: 1px solid var(--border-light);
            color: var(--text-main);
            padding: 1.2rem;
            width: 100%;
            margin-bottom: 1.5rem;
            box-sizing: border-box;
            font-family: inherit;
            font-size: 1.5rem;
            text-align: center;
            letter-spacing: 0.5rem;
        }

        input:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        button {
            background: var(--accent-color);
            color: #fff;
            border: none;
            padding: 1rem;
            width: 100%;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        button:hover {
            background: #fff;
            color: #000;
        }

        .error {
            color: #FF1100;
            font-size: 0.8rem;
            margin-bottom: 1.5rem;
            text-transform: uppercase;
        }

        .resend-link {
            display: block;
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.8rem;
            color: #666;
            text-decoration: none;
            text-transform: uppercase;
        }

        .resend-link:hover {
            color: var(--accent-color);
        }
    </style>
</head>
<body>
    <div class="verify-card">
        <h1>CMS // VERIFY OTP</h1>
        <p>A 5-digit security code has been transmitted to: <br><span class="email-display"><%= email %></span></p>
        
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <form action="/verify-otp" method="POST">
            <input type="hidden" name="email" value="<%= email %>">
            <input type="text" name="otp" placeholder="00000" maxlength="5" required autocomplete="one-time-code">
            <button type="submit">Verify & Create Account</button>
        </form>
        
        <a href="/register" class="resend-link">Back to registration</a>
    </div>
</body>
</html>
