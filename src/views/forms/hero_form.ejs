<div class="card">
    <div class="status-badge">SECTION // STATUS</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
            <label>STATUS TEXT</label>
            <input type="text" name="status[text]" value="<%= data.status.text %>">
        </div>
        <div>
            <label>ACTIVE STATUS</label>
            <select name="status[active]">
                <option value="true" <%= data.status.active ? 'selected' : '' %>>SYS.ONLINE</option>
                <option value="false" <%= !data.status.active ? 'selected' : '' %>>SYS.OFFLINE</option>
            </select>
        </div>
    </div>

    <div class="status-badge">SECTION // TITLE</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
            <label>SOLID TITLE (UPPER)</label>
            <input type="text" name="title[solid]" value="<%= data.title.solid %>">
        </div>
        <div>
            <label>OUTLINE TITLE (LOWER)</label>
            <input type="text" name="title[outline]" value="<%= data.title.outline %>">
        </div>
    </div>

    <div class="status-badge">SECTION // ROLES</div>
    <label>ROLES (COMMA SEPARATED)</label>
    <input type="text" name="roles" value="<%= data.roles.join(', ') %>">

    <div class="status-badge">SECTION // METRICS</div>
    <div id="metrics-container">
        <% data.metrics.forEach((metric, index) => { %>
            <div class="card metric-item" style="margin-bottom: 1rem; padding: 1.5rem; border-color: rgba(255,255,255,0.05); position: relative;">
                <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1rem;">
                    <div>
                        <label>LABEL</label>
                        <input type="text" name="metrics[<%= index %>][label]" value="<%= metric.label %>">
                    </div>
                    <div>
                        <label>VALUE</label>
                        <input type="text" name="metrics[<%= index %>][value]" value="<%= metric.value %>">
                    </div>
                    <div>
                        <label>SUB</label>
                        <input type="text" name="metrics[<%= index %>][sub]" value="<%= metric.sub %>">
                    </div>
                    <div>
                        <label>HIGHLIGHT</label>
                        <select name="metrics[<%= index %>][highlight]">
                            <option value="true" <%= metric.highlight ? 'selected' : '' %>>YES</option>
                            <option value="false" <%= !metric.highlight ? 'selected' : '' %>>NO</option>
                        </select>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
    <button type="button" onclick="addNewMetric()" style="background: #222; margin-top: 1rem; font-size: 0.7rem; width: auto; padding: 0.5rem 1rem;">+ ADD METRIC</button>
</div>

<script>
    function addNewMetric() {
        const container = document.getElementById('metrics-container');
        const index = Date.now(); // Use timestamp for unique indexing in form
        const div = document.createElement('div');
        div.className = 'card metric-item';
        div.style.marginBottom = '1rem';
        div.style.padding = '1.5rem';
        div.style.borderColor = 'rgba(0,255,65,0.3)';
        div.style.position = 'relative';

        div.innerHTML = `
            <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1rem;">
                <div>
                    <label>LABEL</label>
                    <input type="text" name="metrics[${index}][label]" placeholder="EXPERIENCE">
                </div>
                <div>
                    <label>VALUE</label>
                    <input type="text" name="metrics[${index}][value]" placeholder="5+">
                </div>
                <div>
                    <label>SUB</label>
                    <input type="text" name="metrics[${index}][sub]" placeholder="YEARS">
                </div>
                <div>
                    <label>HIGHLIGHT</label>
                    <select name="metrics[${index}][highlight]">
                        <option value="true">YES</option>
                        <option value="false" selected>NO</option>
                    </select>
                </div>
            </div>
        `;
        container.appendChild(div);
    }
</script>

