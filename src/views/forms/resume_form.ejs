<div class="card">
    <div class="status-badge">GLOBAL // RESUME LINK</div>
    <label>RESUME PDF URL (DIRECT LINK)</label>
    <input type="text" name="resumeUrl" value="<%= data.resumeUrl %>" placeholder="https://drive.google.com/your-resume.pdf">

    <div class="status-badge" style="margin-top: 2rem;">SECTION // EXPERIENCE</div>
    <div id="experience-list">
        <% data.experience.forEach((exp, index) => { %>
            <div class="card" style="margin-bottom: 1rem; padding: 1.5rem; border-color: rgba(255,255,255,0.05); position: relative;">
                <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                    <div>
                        <label>ROLE</label>
                        <input type="text" name="experience[<%= index %>][role]" value="<%= exp.role %>">
                    </div>
                    <div>
                        <label>PERIOD</label>
                        <input type="text" name="experience[<%= index %>][year]" value="<%= exp.year %>">
                    </div>
                </div>
                <label>COMPANY</label>
                <input type="text" name="experience[<%= index %>][company]" value="<%= exp.company %>">
                <label>DESCRIPTION</label>
                <textarea name="experience[<%= index %>][description]" style="height: 80px;"><%= exp.description %></textarea>
            </div>
        <% }) %>
    </div>
    <button type="button" onclick="addNewEntry('experience')" style="background: #222; margin-top: 1rem; font-size: 0.7rem; width: auto; padding: 0.5rem 1rem;">+ ADD EXPERIENCE ENTRY</button>

    <div class="status-badge" style="margin-top: 2rem;">SECTION // EDUCATION</div>
    <div id="education-list">
        <% data.education.forEach((edu, index) => { %>
            <div class="card" style="margin-bottom: 1rem; padding: 1.5rem; border-color: rgba(255,255,255,0.05); position: relative;">
                <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                    <div>
                        <label>DEGREE</label>
                        <input type="text" name="education[<%= index %>][degree]" value="<%= edu.degree %>">
                    </div>
                    <div>
                        <label>PERIOD</label>
                        <input type="text" name="education[<%= index %>][year]" value="<%= edu.year %>">
                    </div>
                </div>
                <label>INSTITUTION</label>
                <input type="text" name="education[<%= index %>][institution]" value="<%= edu.institution %>">
                <label>DESCRIPTION</label>
                <textarea name="education[<%= index %>][description]" style="height: 80px;"><%= edu.description %></textarea>
            </div>
        <% }) %>
    </div>
    <button type="button" onclick="addNewEntry('education')" style="background: #222; margin-top: 1rem; font-size: 0.7rem; width: auto; padding: 0.5rem 1rem;">+ ADD EDUCATION ENTRY</button>

    <div class="status-badge" style="margin-top: 2rem;">SECTION // SKILLS</div>
    <div id="skills-list">
        <% data.skills.forEach((skillGroup, index) => { %>
            <div class="card" style="margin-bottom: 1rem; padding: 1.5rem; border-color: rgba(255,255,255,0.05); position: relative;">
                <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
                <label>SKILL CATEGORY</label>
                <input type="text" name="skills[<%= index %>][category]" value="<%= skillGroup.category %>">
                <label>ITEMS (COMMA SEPARATED)</label>
                <input type="text" name="skills[<%= index %>][items]" value="<%= skillGroup.items.join(', ') %>">
            </div>
        <% }) %>
    </div>
    <button type="button" onclick="addNewSkillGroup()" style="background: #222; margin-top: 1rem; font-size: 0.7rem; width: auto; padding: 0.5rem 1rem;">+ ADD SKILL GROUP</button>
</div>

<script>
    function addNewEntry(type) {
        const container = document.getElementById(type + '-list');
        const index = Date.now();
        const div = document.createElement('div');
        div.className = 'card';
        div.style.marginBottom = '1rem';
        div.style.padding = '1.5rem';
        div.style.borderColor = 'rgba(0,255,65,0.3)';
        div.style.position = 'relative';

        if (type === 'experience') {
            div.innerHTML = `
                <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                    <div>
                        <label>ROLE</label>
                        <input type="text" name="experience[${index}][role]" placeholder="NEW ROLE">
                    </div>
                    <div>
                        <label>PERIOD</label>
                        <input type="text" name="experience[${index}][year]" placeholder="YEAR — PRESENT">
                    </div>
                </div>
                <label>COMPANY</label>
                <input type="text" name="experience[${index}][company]" placeholder="COMPANY NAME">
                <label>DESCRIPTION</label>
                <textarea name="experience[${index}][description]" style="height: 80px;"></textarea>
            `;
        } else if (type === 'education') {
            div.innerHTML = `
                <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                    <div>
                        <label>DEGREE</label>
                        <input type="text" name="education[${index}][degree]" placeholder="NEW DEGREE">
                    </div>
                    <div>
                        <label>PERIOD</label>
                        <input type="text" name="education[${index}][year]" placeholder="YEAR — YEAR">
                    </div>
                </div>
                <label>INSTITUTION</label>
                <input type="text" name="education[${index}][institution]" placeholder="INSTITUTION NAME">
                <label>DESCRIPTION</label>
                <textarea name="education[${index}][description]" style="height: 80px;"></textarea>
            `;
        }
        container.appendChild(div);
    }

    function addNewSkillGroup() {
        const container = document.getElementById('skills-list');
        const index = Date.now();
        const div = document.createElement('div');
        div.className = 'card';
        div.style.marginBottom = '1rem';
        div.style.padding = '1.5rem';
        div.style.borderColor = 'rgba(0,255,65,0.3)';
        div.style.position = 'relative';

        div.innerHTML = `
            <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
            <label>SKILL CATEGORY</label>
            <input type="text" name="skills[${index}][category]" placeholder="FRAMEWORKS">
            <label>ITEMS (COMMA SEPARATED)</label>
            <input type="text" name="skills[${index}][items]" placeholder="React, Node.js, Express">
        `;
        container.appendChild(div);
    }
</script>

