<div class="card">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
            <label>TITLE</label>
            <input type="text" name="title" value="<%= data.title %>">
        </div>
        <div>
            <label>SUBTITLE</label>
            <input type="text" name="subtitle" value="<%= data.subtitle %>">
        </div>
    </div>
    
    <label>EMAIL ADDRESS</label>
    <input type="email" name="email" value="<%= data.email %>">
    
    <label>DESCRIPTION</label>
    <textarea name="description" style="height: 100px;"><%= data.description %></textarea>

    <div class="status-badge">SECTION // SOCIAL LINKS</div>
    <div id="socials-list">
        <% data.socials.forEach((social, index) => { %>
            <div class="card" style="margin-bottom: 1rem; padding: 1rem; border-color: rgba(255,255,255,0.05);">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        <label>PLATFORM</label>
                        <input type="text" name="socials[<%= index %>][platform]" value="<%= social.platform %>">
                    </div>
                    <div>
                        <label>HANDLE</label>
                        <input type="text" name="socials[<%= index %>][handle]" value="<%= social.handle %>">
                    </div>
                </div>
                <label>URL</label>
                <input type="text" name="socials[<%= index %>][url]" value="<%= social.url %>">
                <input type="hidden" name="socials[<%= index %>][id]" value="<%= social.id %>">
            </div>
        <% }) %>
    </div>
    <button type="button" onclick="addNewSocial()" style="background: #222; margin-top: 1rem; font-size: 0.7rem; width: auto; padding: 0.5rem 1rem;">+ ADD SOCIAL LINK</button>
</div>

<script>
    function addNewSocial() {
        const container = document.getElementById('socials-list');
        const index = container.children.length;
        const div = document.createElement('div');
        div.className = 'card';
        div.style.marginBottom = '1rem';
        div.style.padding = '1rem';
        div.style.borderColor = 'rgba(255,17,0,0.3)';

        div.innerHTML = `
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label>PLATFORM</label>
                    <input type="text" name="socials[${index}][platform]" placeholder="GITHUB">
                </div>
                <div>
                    <label>HANDLE</label>
                    <input type="text" name="socials[${index}][handle]" placeholder="@USERNAME">
                </div>
            </div>
            <label>URL</label>
            <input type="text" name="socials[${index}][url]" placeholder="https://...">
            <input type="hidden" name="socials[${index}][id]" value="${index + 1}">
        `;
        container.appendChild(div);
    }
</script>
