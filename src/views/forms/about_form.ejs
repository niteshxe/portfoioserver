<div class="card">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
            <label>TITLE</label>
            <input type="text" name="title" value="<%= data.title %>">
        </div>
        <div>
            <label>SUBTITLE</label>
            <input type="text" name="subtitle" value="<%= data.subtitle %>">
        </div>
    </div>

    <div class="status-badge">SECTION // BIOGRAPHY PARAGRAPHS</div>
    <div id="paragraphs-list">
        <% data.paragraphs.forEach((p, index) => { %>
            <div class="card para-item" style="margin-bottom: 1.5rem; padding: 1.5rem; position: relative; border-color: rgba(255,255,255,0.05);">
                <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
                <label>PARAGRAPH</label>
                <textarea name="paragraphs[<%= index %>]" style="height: 100px;"><%= p %></textarea>
            </div>
        <% }) %>
    </div>
    <button type="button" onclick="addNewPara()" style="background: #222; margin-top: 1rem; margin-bottom: 2rem; font-size: 0.7rem; width: auto; padding: 0.5rem 1rem;">+ ADD PARAGRAPH</button>

    <div class="status-badge">SECTION // EXPERIENCE OVERVIEW</div>
    <div id="about-exp-list">
        <% data.experience.forEach((exp, index) => { %>
            <div class="card" style="margin-bottom: 1rem; padding: 1.5rem; border-color: rgba(255,255,255,0.05); position: relative;">
                <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                    <div>
                        <label>ROLE</label>
                        <input type="text" name="about_exp[<%= index %>][role]" value="<%= exp.role %>">
                    </div>
                    <div>
                        <label>PERIOD</label>
                        <input type="text" name="about_exp[<%= index %>][period]" value="<%= exp.period %>">
                    </div>
                </div>
                <label>COMPANY</label>
                <input type="text" name="about_exp[<%= index %>][company]" value="<%= exp.company %>">
                <label>DESCRIPTION</label>
                <textarea name="about_exp[<%= index %>][description]" style="height: 80px;"><%= exp.description %></textarea>
                <input type="hidden" name="about_exp[<%= index %>][id]" value="<%= exp.id %>">
            </div>
        <% }) %>
    </div>
    <button type="button" onclick="addNewAboutExp()" style="background: #222; margin-top: 1rem; margin-bottom: 2rem; font-size: 0.7rem; width: auto; padding: 0.5rem 1rem;">+ ADD EXP ENTRY</button>

    <div class="status-badge">SECTION // SKILLS SUMMARY</div>
    <label>SKILLS (COMMA SEPARATED)</label>
    <textarea name="skills" style="height: 100px;"><%= data.skills.join(', ') %></textarea>
</div>

<script>
    function addNewPara() {
        const container = document.getElementById('paragraphs-list');
        const index = Date.now();
        const div = document.createElement('div');
        div.className = 'card para-item';
        div.style.marginBottom = '1.5rem';
        div.style.padding = '1.5rem';
        div.style.borderColor = 'rgba(0,255,65,0.3)';
        div.style.position = 'relative';

        div.innerHTML = `
            <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
            <label>NEW PARAGRAPH</label>
            <textarea name="paragraphs[${index}]" style="height: 100px;"></textarea>
        `;
        container.appendChild(div);
    }

    function addNewAboutExp() {
        const container = document.getElementById('about-exp-list');
        const index = Date.now();
        const div = document.createElement('div');
        div.className = 'card';
        div.style.marginBottom = '1rem';
        div.style.padding = '1.5rem';
        div.style.borderColor = 'rgba(0,255,65,0.3)';
        div.style.position = 'relative';

        div.innerHTML = `
            <button type="button" onclick="this.parentElement.remove()" style="position: absolute; top: 1rem; right: 1rem; width: auto; background: rgba(255,0,0,0.1); color: var(--accent-color); border: 1px solid var(--accent-color); padding: 0.3rem 0.6rem; font-size: 0.6rem;">DELETE</button>
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                <div>
                    <label>ROLE</label>
                    <input type="text" name="about_exp[${index}][role]" placeholder="NEW ROLE">
                </div>
                <div>
                    <label>PERIOD</label>
                    <input type="text" name="about_exp[${index}][period]" placeholder="202X — 202Y">
                </div>
            </div>
            <label>COMPANY</label>
            <input type="text" name="about_exp[${index}][company]" placeholder="COMPANY NAME">
            <label>DESCRIPTION</label>
            <textarea name="about_exp[${index}][description]" style="height: 80px;"></textarea>
            <input type="hidden" name="about_exp[${index}][id]" value="${index}">
        `;
        container.appendChild(div);
    }
</script>
